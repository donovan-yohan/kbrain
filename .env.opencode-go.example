# kbrain + OpenCode Go example configuration
#
# Copy to .env and fill in the required placeholders below:
#   1. OPENCODE_GO_API_KEY — your OpenCode Go subscription key
#   2. GBRAIN_DATABASE_URL — shared Postgres connection string over Tailscale
#   3. *_TAILNET_HOST placeholders — your tailnet Postgres/Ollama hostnames or IPs
#
# Then run: ./scripts/install-opencode-go.sh
#
# This config routes:
#   - Subagents → OpenCode Go via OpenAI-compatible /chat/completions + x-api-key
#   - Query expansion → OpenCode Go via OpenAI-compatible /chat/completions + x-api-key
#   - Embeddings → Ollama over Tailscale (Go has no embedding models)
#   - Postgres → Postgres over Tailscale
#
# OpenCode Go model IDs for direct API calls are raw IDs like kimi-k2.6,
# deepseek-v4-flash, qwen3.6-plus — not opencode-go/* config IDs.

# ── REQUIRED — per-client ────────────────────────────────────────────────

# OpenCode Go subscription API key. Get it from https://opencode.ai/zen
# after subscribing to the Go tier.
OPENCODE_GO_API_KEY=REPLACE_WITH_OPENCODE_GO_KEY

# Postgres connection string for the shared Tailscale kbrain backend.
# Must include user, password, host, port, database. pgvector extension required.
# Example: postgresql://kbrain:***@postgres.your-tailnet.ts.net:5432/kbrain?sslmode=disable
GBRAIN_DATABASE_URL=postgresql://USER:PASSWORD@POSTGRES_TAILNET_HOST:5432/kbrain?sslmode=disable

# ── OpenCode Go chat config ──────────────────────────────────────────────

# Subagent jobs use the OpenAI SDK against OpenCode Go's OpenAI-compatible
# chat completions endpoint. OpenCode Go expects x-api-key auth.
GBRAIN_SUBAGENT_PROVIDER=openai-compat
GBRAIN_SUBAGENT_BASE_URL=https://opencode.ai/zen/go/v1
GBRAIN_SUBAGENT_API_KEY=${OPENCODE_GO_API_KEY}
GBRAIN_SUBAGENT_MODEL=kimi-k2.6

# Query expansion uses the same OpenAI-compatible API shape.
EXPANSION_PROVIDER=openai-compat
EXPANSION_BASE_URL=https://opencode.ai/zen/go/v1
EXPANSION_API_KEY=${OPENCODE_GO_API_KEY}
EXPANSION_MODEL=deepseek-v4-flash

# ── Dream/autopilot model defaults ───────────────────────────────────────
# The installer writes these config keys after init. They are listed here for
# visibility; direct OpenCode Go API calls use raw model IDs, not opencode-go/*.
#
#   gbrain config set dream.synthesize.model         kimi-k2.6
#   gbrain config set dream.synthesize.verdict_model deepseek-v4-flash
#   gbrain config set dream.patterns.model           kimi-k2.6

# ── Embeddings → Ollama over Tailscale (Go has no embedders) ────────────

# Ollama on the tailnet serving an OpenAI-compatible /v1/embeddings endpoint.
# Setup once on the shared Ollama host:
#   docker run -d --name ollama -p 11434:11434 -v /opt/ollama:/root/.ollama ollama/ollama
#   docker exec ollama ollama pull mxbai-embed-large
EMBEDDING_BASE_URL=http://OLLAMA_TAILNET_HOST:11434/v1
OPENAI_BASE_URL=http://OLLAMA_TAILNET_HOST:11434/v1
EMBEDDING_MODEL=mxbai-embed-large
EMBEDDING_DIMENSIONS=1024

# Ollama ignores the API key but the OpenAI SDK requires a non-empty value.
OPENAI_API_KEY=ollama

# ── Optional — autopilot tuning ─────────────────────────────────────────

# Max concurrent OpenAI-compatible chat requests. Lower if Go rate-limits.
GBRAIN_ANTHROPIC_MAX_INFLIGHT=4

# Minion mode. `pain_triggered` is the default routing rule; `off` disables
# the durable job queue entirely (PGLite installs only).
# GBRAIN_MINION_MODE=pain_triggered
